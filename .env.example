# ────────────────────────────────────────────────────────────
# CodeZone · 环境变量示例
# 复制为 .env 并填入真实值:  cp .env.example .env
# ────────────────────────────────────────────────────────────

# 运行环境 (development | production)
NODE_ENV=development

# ── PostgreSQL 数据库 ──
# 本地 Docker: postgres://codezone:codezone@localhost:5432/codezone
DATABASE_URL=postgres://codezone:codezone@localhost:5432/codezone

# ── JWT 认证 ──
# 生产环境务必替换为强随机串 (建议 >= 32 字符)
JWT_SECRET=codezone-dev-secret-change-in-prod
JWT_EXPIRES_IN=7d

# ── API 服务 ──
API_PORT=3001
PORT=3001

# ── CORS ──
# 多个来源用逗号分隔: http://localhost:5173,https://codezone.app
CORS_ORIGIN=http://localhost:5173

# ── GitHub OAuth ──
# 拆分部署时回调地址指向后端域名,如 https://codezone-api.up.railway.app/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/auth/github/callback

# ── 前端 (apps/web) 构建时注入 ──
# 拆分部署:VITE_API_BASE 指向后端 API,VITE_WS_BASE 指向后端 WebSocket
# 同域部署或本地开发可不设(自动回退到 /api 和同源 /ws)
# VITE_API_BASE=https://codezone-api.up.railway.app/api
# VITE_WS_BASE=wss://codezone-api.up.railway.app/ws
