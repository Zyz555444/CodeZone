# ============================================
# 数据库配置
# ============================================
DB_USER=codezone
DB_PASSWORD=your_secure_password_here
DB_NAME=codezone
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ============================================
# 服务配置
# ============================================
FRONTEND_URL=http://localhost:12321
PORT=10101
